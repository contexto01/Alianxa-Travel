---
import { getCollection } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import WhatsAppFloat from '../../components/WhatsAppFloat.astro'

const destinos = await getCollection('destinos')
const destinosDestacados = destinos.filter((d) => d.data.destacado)
const destinosPorRegion = destinos.reduce(
  (acc, destino) => {
    const region = destino.data.region
    if (!acc[region]) acc[region] = []
    acc[region].push(destino)
    return acc
  },
  {} as Record<string, typeof destinos>
)

const regionNames: Record<string, string> = {
  europa: 'Europa',
  norteamerica: 'Norteamérica',
  sudamerica: 'Sudamérica',
  centroamerica: 'Centroamérica',
  caribe: 'Caribe',
  asia: 'Asia',
  'medio-oriente': 'Medio Oriente',
  oceania: 'Oceanía',
  africa: 'África'
}
---

<Layout
  title="Todos los Destinos | Viajes Nacionales e Internacionales — Alianxa Travel"
  description="Explora todos nuestros destinos disponibles. Viajes a Europa, América, Asia, Oceanía y más. Paquetes personalizados desde Colombia con Alianxa Travel."
>
  <Header />

  <main>
    <!-- Hero -->
    <section
      class="relative py-24 lg:py-32 bg-gradient-to-br from-brand-blue via-brand-dark to-gray-900 overflow-hidden"
    >
      <div class="absolute inset-0">
        <img src="/portada.webp" alt="" class="w-full h-full object-cover opacity-20" />
        <div
          class="absolute inset-0 opacity-10"
          style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"
        >
        </div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-white">
        <span
          class="inline-block px-4 py-1.5 bg-white/15 backdrop-blur-sm border border-white/25 rounded-full text-sm font-bold mb-6"
        >
          🌍 Explora el mundo
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black mb-6 leading-tight">
          Todos nuestros<br />
          <span class="text-brand-yellow">destinos</span>
        </h1>
        <p class="text-xl text-white/80 mb-8 max-w-2xl mx-auto">
          Más de {destinos.length} destinos en todo el mundo esperándote. Desde playas paradisíacas
          hasta ciudades icónicas.
        </p>
        <a
          href="#destinos"
          class="inline-flex items-center gap-2 px-7 py-3.5 bg-brand-yellow text-brand-dark font-bold rounded-full hover:bg-yellow-400 hover:scale-105 transition-all duration-300 shadow-lg"
        >
          Ver todos los destinos ↓
        </a>
      </div>
    </section>

    <!-- Destinos Destacados -->
    {
      destinosDestacados.length > 0 && (
        <section class="py-20 bg-white">
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12">
              <h2 class="text-3xl md:text-4xl font-black text-brand-dark mb-4">
                Destinos destacados
              </h2>
              <p class="text-gray-500 text-lg">Los favoritos de nuestros viajeros</p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
              {destinosDestacados.map((destino) => (
                <a
                  href={`/destinos/${destino.slug}`}
                  class="group block bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-hover transition-all duration-300 hover:-translate-y-2"
                >
                  <div class="relative h-56 overflow-hidden">
                    <img
                      src={destino.data.imagen}
                      alt={`${destino.data.nombre}, ${destino.data.pais}`}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
                    <div class="absolute bottom-4 left-4 text-white">
                      <h3 class="font-black text-2xl mb-1">{destino.data.nombre}</h3>
                      <p class="text-sm text-white/80 flex items-center gap-1">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                          <path
                            fill-rule="evenodd"
                            d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                            clip-rule="evenodd"
                          />
                        </svg>
                        {destino.data.pais}
                      </p>
                    </div>
                    {destino.data.tagRegion && (
                      <span class="absolute top-3 right-3 bg-brand-yellow text-brand-dark text-xs font-bold px-3 py-1 rounded-full">
                        {destino.data.tagRegion}
                      </span>
                    )}
                  </div>
                  <div class="p-5">
                    <p class="text-gray-600 text-sm mb-4 line-clamp-2">
                      {destino.data.descripcion}
                    </p>
                    <div class="flex items-center justify-between">
                      <div>
                        <p class="text-xs text-gray-400 mb-1">Desde</p>
                        <p class="text-2xl font-black text-brand-red">
                          ${destino.data.precioDesde}
                        </p>
                      </div>
                      <span class="text-brand-blue font-bold text-sm group-hover:translate-x-1 transition-transform">
                        Ver más →
                      </span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Destinos por Región -->
    <section id="destinos" class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-black text-brand-dark mb-4">
            Explora por región
          </h2>
          <p class="text-gray-500 text-lg">Encuentra tu próximo destino por continente</p>
        </div>

        <div class="space-y-16">
          {
            Object.entries(destinosPorRegion).map(([region, destinos]) => (
              <div>
                <h3 class="text-2xl font-black text-brand-dark mb-6 flex items-center gap-2">
                  <span class="w-8 h-8 bg-brand-blue/10 rounded-lg flex items-center justify-center text-brand-blue">
                    {region === 'europa'
                      ? '🏰'
                      : region === 'norteamerica'
                        ? '🗽'
                        : region === 'sudamerica'
                          ? '🌿'
                          : region === 'asia'
                            ? '🏯'
                            : region === 'caribe'
                              ? '🏝️'
                              : '🌍'}
                  </span>
                  {regionNames[region] || region}
                  <span class="text-base font-normal text-gray-400">({destinos.length})</span>
                </h3>

                <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
                  {destinos.map((destino) => (
                    <a
                      href={`/destinos/${destino.slug}`}
                      class="group block bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300"
                    >
                      <div class="relative h-40 overflow-hidden">
                        <img
                          src={destino.data.imagen}
                          alt={`${destino.data.nombre}, ${destino.data.pais}`}
                          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                          loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
                        <div class="absolute bottom-3 left-3 text-white">
                          <h4 class="font-black text-lg">{destino.data.nombre}</h4>
                          <p class="text-xs text-white/80">{destino.data.pais}</p>
                        </div>
                      </div>
                      <div class="p-3">
                        <div class="flex items-center justify-between">
                          <div>
                            <p class="text-xs text-gray-400">Desde</p>
                            <p class="text-xl font-black text-brand-dark">
                              ${destino.data.precioDesde}
                            </p>
                          </div>
                          <span class="text-brand-blue text-xs font-bold group-hover:translate-x-1 transition-transform">
                            Ver →
                          </span>
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-brand-yellow">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="text-5xl mb-4">🌍</div>
        <h2 class="text-3xl md:text-4xl font-black text-brand-dark mb-4">
          ¿No encuentras tu destino ideal?
        </h2>
        <p class="text-gray-700 text-lg mb-8">
          Contáctanos y diseñamos un paquete completamente personalizado para ti
        </p>
        <a
          href="https://wa.me/5733246250212?text=Hola!%20Quiero%20informaci%C3%B3n%20sobre%20un%20destino%20personalizado"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 px-8 py-4 bg-emerald-500 text-white font-black text-lg rounded-full hover:bg-emerald-400 hover:scale-105 transition-all duration-300 shadow-lg"
        >
          <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24">
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
            ></path>
            <path
              d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.535 5.845L0 24l6.335-1.533C8.049 23.455 9.982 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.807 0-3.496-.487-4.951-1.335l-.355-.21-3.76.91.951-3.659-.232-.375C2.49 15.583 2 13.848 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"
            ></path>
          </svg>
          Cotizar destino personalizado
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>
