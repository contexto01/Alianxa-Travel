---
import { getCollection, type CollectionEntry } from 'astro:content'
import Layout from '../../layouts/Layout.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import WhatsAppFloat from '../../components/WhatsAppFloat.astro'

export async function getStaticPaths() {
  const destinos = await getCollection('destinos')
  return destinos.map((destino) => ({
    params: { slug: destino.slug },
    props: { destino }
  }))
}

type Props = {
  destino: CollectionEntry<'destinos'>
}

const { destino } = Astro.props
const { Content } = await destino.render()

const paquetes = await getCollection('paquetes')
const paquetesRelacionados = paquetes
  .filter(
    (p) =>
      p.data.destinoSlug === destino.slug ||
      p.data.nombre.toLowerCase().includes(destino.data.nombre.toLowerCase())
  )
  .slice(0, 3)

const whatsappURL = `https://wa.me/573001234567?text=${destino.data.cta.whatsapp}`
---

<Layout
  title={destino.data.seo.title}
  description={destino.data.seo.description}
  ogImage={destino.data.imagen}
>
  <Header />

  <main>
    <!-- HERO -->
    <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0">
        <img
          src={destino.data.imagen}
          alt={`Viajes a ${destino.data.nombre} ${destino.data.pais}`}
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/40 to-black/80">
        </div>
      </div>

      <div class="relative z-10 max-w-5xl mx-auto px-6 text-center text-white pt-28">
        <span
          class="inline-block px-4 py-1.5 bg-white/20 backdrop-blur border border-white/30 rounded-full text-sm font-bold mb-4"
        >
          {destino.data.tagRegion || destino.data.pais}
        </span>

        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-black mb-4">
          {destino.data.nombre}
        </h1>

        <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-8">
          {destino.data.descripcion}
        </p>

        <div class="flex flex-wrap gap-6 justify-center items-center">
          <div class="bg-white/15 backdrop-blur rounded-2xl px-7 py-5 border border-white/20">
            <p class="text-sm text-white/70">Desde</p>
            <p class="text-4xl font-black text-brand-yellow">
              ${destino.data.precioDesde}
            </p>
            <p class="text-sm text-white/60">{destino.data.moneda} por persona</p>
          </div>

          <a
            href={whatsappURL}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-3 px-9 py-4 bg-emerald-500 text-white font-black text-lg rounded-full hover:bg-emerald-400 hover:scale-105 transition-all shadow-xl btn-whatsapp-conversion btn-whatsapp-conversion"
          >
            Cotizar por WhatsApp
          </a>
        </div>
      </div>
    </section>

    <!-- GALERÍA -->
    {
      destino.data.imagenes && destino.data.imagenes.length > 0 && (
        <section class="py-14 bg-gray-50">
          <div class="max-w-7xl mx-auto px-6">
            <div class="grid md:grid-cols-3 gap-4">
              {destino.data.imagenes!.map((img, i) => (
                <div class="rounded-2xl overflow-hidden h-64 shadow-card">
                  <img
                    src={img}
                    alt={`${destino.data.nombre} ${i + 1}`}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- CONTENIDO COMERCIAL -->
    <section id="contenido" class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <div class="space-y-14 text-gray-700">
          <!-- IMPORTANTE:
               Aquí el Markdown manda.
               Ya NO usamos prose -->
          <Content />
        </div>
      </div>
    </section>

    <!-- PAQUETES RELACIONADOS -->
    {
      paquetesRelacionados.length > 0 && (
        <section class="py-20 bg-gray-50">
          <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-12">
              <h2 class="text-3xl md:text-4xl font-black text-brand-dark mb-3">
                Paquetes disponibles
              </h2>
              <p class="text-gray-500">
                Elige el paquete ideal para tu viaje a {destino.data.nombre}
              </p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
              {paquetesRelacionados.map((paquete) => (
                <div class="bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-hover transition-all hover:-translate-y-2">
                  <div class="relative h-52">
                    <img
                      src={paquete.data.imagen}
                      alt={paquete.data.nombre}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent" />
                  </div>

                  <div class="p-6">
                    <h3 class="text-xl font-black mb-2">{paquete.data.nombre}</h3>

                    <div class="flex items-baseline gap-2 mb-4">
                      <span class="text-sm text-gray-500">Desde</span>
                      <span class="text-4xl font-black text-brand-red">
                        ${paquete.data.precio}
                      </span>
                      <span class="text-sm text-gray-400">{paquete.data.moneda}</span>
                    </div>

                    <a
                      href={`https://wa.me/573001234567?text=${paquete.data.whatsapp}`}
                      target="_blank"
                      rel="noopener"
                      class="block w-full py-3 bg-brand-dark text-white text-center font-bold rounded-xl hover:bg-brand-blue transition"
                    >
                      Reservar ahora →
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- CTA FINAL -->
    <section class="py-20 bg-brand-yellow">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-black text-brand-dark mb-4">
          ¿Listo para viajar a {destino.data.nombre}?
        </h2>
        <p class="text-gray-700 text-lg mb-8 btn-whatsapp-conversion">
          Cotiza ahora y deja tu viaje en manos de expertos
        </p>
        <a
          href={whatsappURL}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-3 px-10 py-5 bg-emerald-500 text-white font-black text-xl rounded-full hover:bg-emerald-400 hover:scale-105 transition-all shadow-xl btn-whatsapp-conversion"
        >
          Cotizar viaje ahora
        </a>
      </div>
    </section>
  </main>

  <Footer />
  <WhatsAppFloat />
</Layout>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "TouristDestination",
    "name": "{destino.data.nombre}",
    "description": "{destino.data.descripcion}",
    "touristType": ["familias", "parejas", "aventura"],
    "containedInPlace": {
      "@type": "Country",
      "name": "{destino.data.pais}"
    }
  }
</script>

<script is:inline>
  function handleWhatsAppClick() {
    if (typeof gtag !== 'undefined') {
      gtag('event', 'conversion', {
        send_to: 'AW-18028497164/SYupCPisqZAcEIyS1JRD',
        value: 1.0,
        currency: 'COP'
      })
    }
  }

  // Esperar a que el DOM cargue para asignar el evento
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.btn-whatsapp-conversion')
    buttons.forEach((button) => {
      button.addEventListener('click', handleWhatsAppClick)
    })
  })
</script>
