---
export interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const {
  title = 'Alianxa Travel | Tu mundo, tu viaje — Agencia de Viajes Colombia',
  description = 'Alianxa Travel, tu agencia de viajes en Colombia. Paquetes nacionales e internacionales, experiencias personalizadas a los mejores destinos del mundo. ¡Cotiza ahora!',
  ogImage = '/Logo.webp'
} = Astro.props

const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site) : ''
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="agencia de viajes, viajes Colombia, paquetes turísticos, viajes internacionales, vacaciones, Alianxa Travel, tours, ecoturismo"
    />
    <meta name="author" content="Alianxa Travel" />
    <meta name="robots" content="index, follow" />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Alianxa Travel" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_CO" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/Logo.webp" />
    <link rel="icon" type="image/png" href="/Logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "TravelAgency",
        "name": "Alianxa Travel",
        "description": "Agencia de viajes que ofrece paquetes nacionales e internacionales personalizados.",
        "url": "https://alianxatravel.com",
        "telephone": "+573001234567",
        "email": "info@alianxatravel.com",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Bogotá",
          "addressCountry": "CO"
        },
        "sameAs": [
          "https://www.instagram.com/alianxatravel",
          "https://www.facebook.com/alianxatravel"
        ]
      }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,300;0,400;0,600;0,700;0,800;0,900;1,800&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <!-- Google Ads / Google Tag -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18028497164"></script>

    <script is:inline>
      window.dataLayer = window.dataLayer || []
      function gtag() {
        dataLayer.push(arguments)
      }
      gtag('js', new Date())
      gtag('config', 'AW-18028497164')
    </script>
  </head>
  <body class="font-body">
    <slot />

    <!-- Scroll reveal script -->
    <script>
      const reveals = document.querySelectorAll('.reveal')
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active')
            }
          })
        },
        { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
      )
      reveals.forEach((el) => observer.observe(el))
    </script>
  </body>
</html>
