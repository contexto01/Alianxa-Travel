---
const destinations = [
  {
    name: 'Río de Janeiro',
    country: 'Brasil',
    image: 'https://images.unsplash.com/photo-1483729558449-99ef09a8c325?w=600&q=80&auto=format&fit=crop',
    tag: 'Sudamérica',
    size: 'lg',
  },
  {
    name: 'Buenos Aires',
    country: 'Argentina',
    image: 'https://images.unsplash.com/photo-1589909202802-8f4aadce1849?w=600&q=80&auto=format&fit=crop',
    tag: 'Sudamérica',
    size: 'sm',
  },
  {
    name: 'Cartagena',
    country: 'Colombia',
    image: 'https://images.unsplash.com/photo-1562327125-6db1e44e9ebb?w=600&q=80&auto=format&fit=crop',
    tag: 'Nacional',
    size: 'sm',
  },
  {
    name: 'Cancún',
    country: 'México',
    image: 'https://images.unsplash.com/photo-1552074284-5e88ef1aef18?w=600&q=80&auto=format&fit=crop',
    tag: 'Norteamérica',
    size: 'sm',
  },
  {
    name: 'Cusco & Machu Picchu',
    country: 'Perú',
    image: 'https://images.unsplash.com/photo-1587595431973-160d0d94add1?w=600&q=80&auto=format&fit=crop',
    tag: 'Sudamérica',
    size: 'sm',
  },
  {
    name: 'Punta Cana',
    country: 'Rep. Dominicana',
    image: 'https://images.unsplash.com/photo-1544551763-46a013bb70d5?w=600&q=80&auto=format&fit=crop',
    tag: 'Caribe',
    size: 'lg',
  },
];
---

<section id="destinos" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14 reveal">
      <span class="inline-block px-4 py-1.5 bg-brand-red/10 text-brand-red text-sm font-bold rounded-full mb-4">
        Destinos destacados
      </span>
      <h2 class="section-title">Descubre el mundo con<br /><span class="text-brand-blue">Alianxa Travel</span></h2>
      <p class="section-subtitle">
        Lugares increíbles del mundo con nuestros paquetes personalizados
      </p>
    </div>

    <!-- Desktop Masonry Grid -->
    <div class="hidden md:grid grid-cols-3 gap-4 reveal">
      <!-- Row 1 -->
      <div class="dest-card h-72 col-span-1 row-span-1">
        <img src={destinations[0].image} alt={destinations[0].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl z-10"></div>
        <div class="absolute bottom-4 left-4 z-20 text-white">
          <p class="font-black text-xl leading-tight">{destinations[0].name}</p>
          <p class="text-sm text-white/75 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            {destinations[0].country}
          </p>
        </div>
        <span class="absolute top-3 right-3 z-20 bg-brand-yellow text-brand-dark text-xs font-bold px-2.5 py-1 rounded-full">{destinations[0].tag}</span>
      </div>

      <div class="dest-card h-72 col-span-1">
        <img src={destinations[1].image} alt={destinations[1].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl z-10"></div>
        <div class="absolute bottom-4 left-4 z-20 text-white">
          <p class="font-black text-xl leading-tight">{destinations[1].name}</p>
          <p class="text-sm text-white/75 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            {destinations[1].country}
          </p>
        </div>
        <span class="absolute top-3 right-3 z-20 bg-brand-blue text-white text-xs font-bold px-2.5 py-1 rounded-full">{destinations[1].tag}</span>
      </div>

      <div class="dest-card h-72 col-span-1">
        <img src={destinations[2].image} alt={destinations[2].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl z-10"></div>
        <div class="absolute bottom-4 left-4 z-20 text-white">
          <p class="font-black text-xl leading-tight">{destinations[2].name}</p>
          <p class="text-sm text-white/75 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            {destinations[2].country}
          </p>
        </div>
        <span class="absolute top-3 right-3 z-20 bg-brand-red text-white text-xs font-bold px-2.5 py-1 rounded-full">{destinations[2].tag}</span>
      </div>

      <!-- Row 2 -->
      <div class="dest-card h-72 col-span-1">
        <img src={destinations[3].image} alt={destinations[3].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl z-10"></div>
        <div class="absolute bottom-4 left-4 z-20 text-white">
          <p class="font-black text-xl leading-tight">{destinations[3].name}</p>
          <p class="text-sm text-white/75 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            {destinations[3].country}
          </p>
        </div>
        <span class="absolute top-3 right-3 z-20 bg-brand-yellow text-brand-dark text-xs font-bold px-2.5 py-1 rounded-full">{destinations[3].tag}</span>
      </div>

      <div class="dest-card h-72 col-span-1">
        <img src={destinations[4].image} alt={destinations[4].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl z-10"></div>
        <div class="absolute bottom-4 left-4 z-20 text-white">
          <p class="font-black text-xl leading-tight">{destinations[4].name}</p>
          <p class="text-sm text-white/75 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            {destinations[4].country}
          </p>
        </div>
        <span class="absolute top-3 right-3 z-20 bg-emerald-500 text-white text-xs font-bold px-2.5 py-1 rounded-full">{destinations[4].tag}</span>
      </div>

      <div class="dest-card h-72 col-span-1">
        <img src={destinations[5].image} alt={destinations[5].name} class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl z-10"></div>
        <div class="absolute bottom-4 left-4 z-20 text-white">
          <p class="font-black text-xl leading-tight">{destinations[5].name}</p>
          <p class="text-sm text-white/75 flex items-center gap-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
            {destinations[5].country}
          </p>
        </div>
        <span class="absolute top-3 right-3 z-20 bg-brand-blue text-white text-xs font-bold px-2.5 py-1 rounded-full">{destinations[5].tag}</span>
      </div>
    </div>

    <!-- Mobile: scroll grid -->
    <div class="md:hidden grid grid-cols-1 gap-4">
      {destinations.map((d) => (
        <div class="dest-card h-52">
          <img src={d.image} alt={d.name} class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl z-10"></div>
          <div class="absolute bottom-4 left-4 z-20 text-white">
            <p class="font-black text-xl">{d.name}</p>
            <p class="text-sm text-white/75">📍 {d.country}</p>
          </div>
          <span class="absolute top-3 right-3 z-20 bg-brand-yellow text-brand-dark text-xs font-bold px-2.5 py-1 rounded-full">{d.tag}</span>
        </div>
      ))}
    </div>

    <div class="text-center mt-10 reveal">
      <a href="#cotizar" class="btn-primary text-base px-8 py-3.5">
        🌍 Quiero cotizar un destino
      </a>
    </div>
  </div>
</section>
