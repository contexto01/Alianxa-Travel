---
import type { CollectionEntry } from 'astro:content';

interface Props {
  destinos: CollectionEntry<'destinos'>[];
}

const { destinos } = Astro.props;
---

<section id="destinos" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14 reveal">
      <span class="inline-block px-4 py-1.5 bg-brand-red/10 text-brand-red text-sm font-bold rounded-full mb-4">
        Destinos destacados
      </span>
      <h2 class="section-title">Descubre el mundo con<br /><span class="text-brand-blue">Alianxa Travel</span></h2>
      <p class="section-subtitle">
        Lugares increíbles del mundo con nuestros paquetes personalizados
      </p>
    </div>

    <!-- Desktop Masonry Grid -->
    <div class="hidden md:grid grid-cols-3 gap-4 reveal">
      {destinos.slice(0, 6).map((destino, index) => (
        <a
          href={`/destinos/${destino.slug}`}
          class="dest-card h-72 col-span-1"
        >
          <img src={destino.data.imagen} alt={`${destino.data.nombre}, ${destino.data.pais}`} class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl z-10"></div>
          <div class="absolute bottom-4 left-4 z-20 text-white">
            <p class="font-black text-xl leading-tight">{destino.data.nombre}</p>
            <p class="text-sm text-white/75 flex items-center gap-1">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              {destino.data.pais}
            </p>
          </div>
          {destino.data.tagRegion && (
            <span class="absolute top-3 right-3 z-20 bg-brand-yellow text-brand-dark text-xs font-bold px-2.5 py-1 rounded-full">
              {destino.data.tagRegion}
            </span>
          )}
        </a>
      ))}
    </div>

    <!-- Mobile: scroll grid -->
    <div class="md:hidden grid grid-cols-1 gap-4">
      {destinos.slice(0, 6).map((destino) => (
        <a href={`/destinos/${destino.slug}`} class="dest-card h-52">
          <img src={destino.data.imagen} alt={`${destino.data.nombre}, ${destino.data.pais}`} class="w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent rounded-xl z-10"></div>
          <div class="absolute bottom-4 left-4 z-20 text-white">
            <p class="font-black text-xl">{destino.data.nombre}</p>
            <p class="text-sm text-white/75">📍 {destino.data.pais}</p>
          </div>
          {destino.data.tagRegion && (
            <span class="absolute top-3 right-3 z-20 bg-brand-yellow text-brand-dark text-xs font-bold px-2.5 py-1 rounded-full">
              {destino.data.tagRegion}
            </span>
          )}
        </a>
      ))}
    </div>

    <div class="text-center mt-10 reveal">
      <a href="/destinos" class="btn-primary text-base px-8 py-3.5">
        🌍 Ver todos los destinos
      </a>
    </div>
  </div>
</section>
