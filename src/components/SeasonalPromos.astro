---
import type { CollectionEntry } from 'astro:content';

interface Props {
  promociones: CollectionEntry<'promociones'>[];
}

const { promociones } = Astro.props;
---

<section id="promociones" class="py-10 lg:py-28 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14 reveal">
      <span class="inline-block px-4 py-1.5 bg-brand-yellow/20 text-yellow-700 text-sm font-bold rounded-full mb-4">
        🌟 Promociones de temporada
      </span>
      <h2 class="section-title">Aprovecha nuestras<br /><span class="text-brand-blue">ofertas especiales</span></h2>
      <p class="section-subtitle">Vive la aventura de tu vida con los mejores paquetes del mercado</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {promociones.map((promo, i) => (
        <article
          class="bg-white rounded-2xl overflow-hidden shadow-card card-hover border border-gray-100 reveal"
          style={`transition-delay: ${i * 80}ms`}
        >
          <!-- Image -->
          <div class="relative h-52 overflow-hidden">
            <img
              src={promo.data.imagen}
              alt={`Viaje a ${promo.data.nombre}, ${promo.data.pais}`}
              class="w-full h-full object-cover transition-transform duration-500 hover:scale-110"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
            <div class="absolute bottom-3 left-4 text-white">
              <h3 class="font-black text-xl">{promo.data.nombre}</h3>
              <p class="text-sm text-white/75">{promo.data.pais}</p>
            </div>
            <span class={`absolute top-3 right-3 ${promo.data.badgeColor} text-white text-xs font-bold px-2.5 py-1 rounded-full`}>
              {promo.data.badge}
            </span>
          </div>

          <!-- Card body -->
          <div class="p-5">
            <div class="flex items-baseline gap-1 mb-4">
              <span class="text-gray-400 text-sm">Desde</span>
              <span class="text-3xl font-black text-brand-red">${promo.data.precio}</span>
              <span class="text-gray-400 text-sm">{promo.data.moneda} por persona</span>
            </div>

            <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-2">Incluye:</p>
            <ul class="space-y-1 mb-5">
              {promo.data.incluye.map((item) => (
                <li class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-emerald-500 shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>

            <a

              href={`/destinos/${promo.data.slugName}`}

              class="block w-full py-3 bg-brand-yellow text-brand-dark text-center font-black rounded-xl hover:bg-yellow-400 transition-all duration-300 hover:scale-[1.02] hover:shadow-md"
            >
              Reservar ahora ✈
            </a>
          </div>
        </article>
      ))}
    </div>
     <div class="text-center mt-10 reveal">
      <a href="/destinos" class="btn-primary text-base px-8 py-3.5">
        🌍 Ver todos los destinos
      </a>
    </div>
  </div>
</section>
