---
---

<section
  id="inicio"
  class="relative min-h-screen flex items-center justify-center overflow-hidden"
  aria-label="Sección principal"
>
  <!-- Background image with overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=1920&q=85&auto=format&fit=crop"
      alt="Playa paradisíaca para viajes con Alianxa Travel"
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/35 to-black/60"></div>
  </div>

  <!-- Decorative shapes -->
  <div class="absolute top-1/4 left-6 w-16 h-16 bg-brand-yellow/20 rounded-full blur-xl z-0 animate-float"></div>
  <div class="absolute bottom-1/3 right-10 w-24 h-24 bg-brand-red/20 rounded-full blur-2xl z-0 animate-float" style="animation-delay:1.2s"></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16">
    <div class="grid lg:grid-cols-2 gap-12 items-center">

      <!-- Hero Text -->
      <div class="text-white text-center lg:text-left">
        <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 text-sm font-semibold mb-6 text-white">
          <span class="w-2 h-2 bg-brand-yellow rounded-full animate-pulse"></span>
          Tu agencia de viajes de confianza
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-black leading-tight mb-6 drop-shadow-lg">
          ¿A qué lugar<br />
          <span class="text-brand-yellow">quieres viajar?</span>
        </h1>
        <p class="text-lg sm:text-xl text-white/85 mb-8 font-medium max-w-lg mx-auto lg:mx-0">
          Viajes nacionales e internacionales a tu medida.<br class="hidden sm:block" />
          <em class="not-italic text-brand-yellow font-semibold">Tu mundo, tu viaje.</em>
        </p>
        <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
          <a href="#destinos" class="btn-primary text-base px-7 py-3.5">
            🌍 Ver destinos
          </a>
          <a href="https://wa.me/573001234567?text=Hola!%20Me%20interesa%20planear%20un%20viaje" target="_blank" rel="noopener" class="btn-outline text-base px-7 py-3.5">
            💬 Chatea con nosotros
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-12 flex flex-wrap gap-8 justify-center lg:justify-start">
          <div class="text-center">
            <p class="text-3xl font-black text-brand-yellow">+500</p>
            <p class="text-sm text-white/70 font-medium">Clientes felices</p>
          </div>
          <div class="w-px bg-white/20 hidden sm:block"></div>
          <div class="text-center">
            <p class="text-3xl font-black text-brand-yellow">+50</p>
            <p class="text-sm text-white/70 font-medium">Destinos</p>
          </div>
          <div class="w-px bg-white/20 hidden sm:block"></div>
          <div class="text-center">
            <p class="text-3xl font-black text-brand-yellow">24/7</p>
            <p class="text-sm text-white/70 font-medium">Asistencia</p>
          </div>
        </div>
      </div>

      <!-- Quote Form -->
      <div id="cotizar" class="bg-white/95 backdrop-blur-md rounded-3xl shadow-hero p-6 sm:p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-brand-blue rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-extrabold text-brand-dark">Cotiza tu paquete</h2>
            <p class="text-sm text-gray-500">Sin costo · Respuesta rápida</p>
          </div>
        </div>

        <form
          id="quote-form"
          action="https://wa.me/573001234567"
          method="get"
          target="_blank"
          class="space-y-4"
          novalidate
        >
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="destino" class="block text-sm font-bold text-gray-700 mb-1.5">
                🌍 Destino *
              </label>
              <input
                type="text"
                id="destino"
                name="destino"
                placeholder="Ej: Cartagena, París, Cancún"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue/40 focus:border-brand-blue transition-all placeholder-gray-400"
              />
            </div>
            <div>
              <label for="pasajeros" class="block text-sm font-bold text-gray-700 mb-1.5">
                👥 Pasajeros *
              </label>
              <select
                id="pasajeros"
                name="pasajeros"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-brand-blue/40 focus:border-brand-blue transition-all bg-white"
              >
                <option value="">Seleccionar</option>
                <option value="1">1 pasajero</option>
                <option value="2">2 pasajeros</option>
                <option value="3">3 pasajeros</option>
                <option value="4">4 pasajeros</option>
                <option value="5+">5 o más</option>
              </select>
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="fecha-ida" class="block text-sm font-bold text-gray-700 mb-1.5">
                📅 Fecha de ida *
              </label>
              <input
                type="date"
                id="fecha-ida"
                name="fecha-ida"
                required
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-brand-blue/40 focus:border-brand-blue transition-all"
              />
            </div>
            <div>
              <label for="fecha-regreso" class="block text-sm font-bold text-gray-700 mb-1.5">
                📅 Fecha de regreso
              </label>
              <input
                type="date"
                id="fecha-regreso"
                name="fecha-regreso"
                class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-brand-blue/40 focus:border-brand-blue transition-all"
              />
            </div>
          </div>

          <div>
            <label for="telefono" class="block text-sm font-bold text-gray-700 mb-1.5">
              📱 Teléfono / WhatsApp *
            </label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              placeholder="+57 300 123 4567"
              required
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-brand-blue/40 focus:border-brand-blue transition-all placeholder-gray-400"
            />
          </div>

          <div id="form-error" class="hidden text-sm text-red-600 font-medium bg-red-50 rounded-lg px-3 py-2"></div>

          <button
            type="submit"
            class="w-full py-4 bg-brand-red text-white font-extrabold text-base rounded-2xl transition-all duration-300 hover:bg-red-600 hover:scale-[1.02] hover:shadow-lg active:scale-[0.98] flex items-center justify-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.535 5.845L0 24l6.335-1.533C8.049 23.455 9.982 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.807 0-3.496-.487-4.951-1.335l-.355-.21-3.76.91.951-3.659-.232-.375C2.49 15.583 2 13.848 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            Cotizar paquete por WhatsApp
          </button>

          <p class="text-xs text-center text-gray-400">
            🔒 Tus datos están seguros. Solo los usamos para contactarte.
          </p>
        </form>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#nosotros" class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-1 text-white/60 hover:text-white transition-colors scroll-bounce" aria-label="Scroll hacia abajo">
    <span class="text-xs font-medium">Descubre más</span>
    <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </a>
</section>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const errorDiv = document.getElementById('form-error')!;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const destino   = (form.querySelector('#destino') as HTMLInputElement).value.trim();
    const pasajeros = (form.querySelector('#pasajeros') as HTMLSelectElement).value;
    const fechaIda  = (form.querySelector('#fecha-ida') as HTMLInputElement).value;
    const telefono  = (form.querySelector('#telefono') as HTMLInputElement).value.trim();

    if (!destino || !pasajeros || !fechaIda || !telefono) {
      errorDiv.textContent = 'Por favor completa los campos obligatorios.';
      errorDiv.classList.remove('hidden');
      return;
    }
    errorDiv.classList.add('hidden');

    const fechaRegreso = (form.querySelector('#fecha-regreso') as HTMLInputElement).value;
    const msg = encodeURIComponent(
      `¡Hola Alianxa Travel! 👋\n\nQuiero cotizar un paquete:\n` +
      `🌍 Destino: ${destino}\n` +
      `👥 Pasajeros: ${pasajeros}\n` +
      `📅 Fecha de ida: ${fechaIda}\n` +
      `${fechaRegreso ? `📅 Fecha de regreso: ${fechaRegreso}\n` : ''}` +
      `📱 Mi WhatsApp: ${telefono}\n\n¡Gracias!`
    );
    window.open(`https://wa.me/573001234567?text=${msg}`, '_blank');
  });
</script>
