<section id="contacto" class="py-16 lg:py-24 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Main CTA Banner -->
    <div class="reveal bg-brand-yellow rounded-3xl p-10 lg:p-14 text-center shadow-xl mb-14">
      <div class="text-5xl mb-4">✈️</div>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-brand-dark mb-4 leading-tight">
        Conecta con nosotros y<br />
        <span class="text-brand-blue">planea tu próxima aventura</span>
      </h2>
      <p class="text-gray-700 text-lg mb-8 max-w-xl mx-auto">
        Nuestro equipo está listo para ayudarte a crear el viaje perfecto, adaptado a tus sueños y presupuesto.
      </p>
      <a
        href="https://wa.me/573001234567?text=Hola!%20Quiero%20planear%20mi%20pr%C3%B3xima%20aventura%20con%20Alianxa%20Travel"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-3 px-8 py-4 bg-emerald-500 text-white font-black text-lg rounded-full hover:bg-emerald-400 hover:scale-105 transition-all duration-300 shadow-lg"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
