        Chatea con nosotros
      </a>
    </div>

    <!-- Contact info cards -->
    <div class="reveal grid sm:grid-cols-3 gap-6 text-center">
      <a
        href="tel:+573001234567"
        class="group p-6 bg-gray-50 rounded-2xl hover:bg-brand-blue hover:text-white transition-all duration-300 border border-gray-100 hover:border-brand-blue hover:shadow-lg"
      >
        <div class="text-3xl mb-3">📞</div>
        <p class="text-sm font-bold text-gray-500 group-hover:text-white/70 mb-1">Llámanos</p>
        <p class="font-extrabold text-brand-dark group-hover:text-white">+57 300 123 4567</p>
      </a>
      <a
        href="mailto:info@alianxatravel.com"
        class="group p-6 bg-gray-50 rounded-2xl hover:bg-brand-red hover:text-white transition-all duration-300 border border-gray-100 hover:border-brand-red hover:shadow-lg"
      >
        <div class="text-3xl mb-3">📧</div>
        <p class="text-sm font-bold text-gray-500 group-hover:text-white/70 mb-1">Escríbenos</p>
        <p class="font-extrabold text-brand-dark group-hover:text-white">info@alianxatravel.com</p>
      </a>
      <div class="group p-6 bg-gray-50 rounded-2xl border border-gray-100">
        <div class="text-3xl mb-3">📍</div>
        <p class="text-sm font-bold text-gray-500 mb-1">Ubicación</p>
        <p class="font-extrabold text-brand-dark">Bogotá, Colombia</p>
      </div>
    </div>
  </div>
</section>
