---
---

<footer class="bg-gray-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand-blue to-brand-red flex items-center justify-center">
            <span class="text-white font-black text-lg">AT</span>
          </div>
          <div>
            <span class="block text-white font-black text-lg leading-tight">Alianxa</span>
            <span class="block text-brand-yellow font-black text-lg leading-tight -mt-1">Travel</span>
          </div>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-5">
          Tu mundo, tu viaje. Creamos experiencias inolvidables que transforman tus sueños en realidad.
        </p>
        <!-- Social links -->
        <div class="flex gap-3">
          <a href="https://facebook.com/alianxatravel" target="_blank" rel="noopener" aria-label="Facebook" class="w-9 h-9 bg-gray-800 rounded-full flex items-center justify-center hover:bg-blue-600 transition-all duration-300 hover:scale-110">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://instagram.com/alianxatravel" target="_blank" rel="noopener" aria-label="Instagram" class="w-9 h-9 bg-gray-800 rounded-full flex items-center justify-center hover:bg-pink-600 transition-all duration-300 hover:scale-110">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="https://x.com/alianxatravel" target="_blank" rel="noopener" aria-label="X / Twitter" class="w-9 h-9 bg-gray-800 rounded-full flex items-center justify-center hover:bg-gray-600 transition-all duration-300 hover:scale-110">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://wa.me/573001234567" target="_blank" rel="noopener" aria-label="WhatsApp" class="w-9 h-9 bg-gray-800 rounded-full flex items-center justify-center hover:bg-emerald-600 transition-all duration-300 hover:scale-110">
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.535 5.845L0 24l6.335-1.533C8.049 23.455 9.982 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.807 0-3.496-.487-4.951-1.335l-.355-.21-3.76.91.951-3.659-.232-.375C2.49 15.583 2 13.848 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-brand-yellow font-extrabold text-base mb-5">Enlaces rápidos</h3>
        <ul class="space-y-2.5">
          {['Inicio', 'Quiénes somos', 'Destinos', 'Promociones', 'Contacto'].map(link => (
            <li>
              <a
                href={`#${link === 'Inicio' ? 'inicio' : link === 'Quiénes somos' ? 'nosotros' : link.toLowerCase()}`}
                class="text-gray-400 hover:text-white text-sm transition-colors flex items-center gap-1.5 group"
              >
                <svg class="w-3 h-3 text-brand-yellow opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                {link}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Destinations -->
      <div>
        <h3 class="text-brand-yellow font-extrabold text-base mb-5">Destinos populares</h3>
        <ul class="space-y-2.5">
          {['Cartagena', 'San Andrés', 'Cancún', 'Punta Cana', 'París', 'Nueva York', 'Bali'].map(dest => (
            <li>
              <a
                href={`https://wa.me/573001234567?text=Quiero%20informaci%C3%B3n%20sobre%20${encodeURIComponent(dest)}`}
                target="_blank"
                rel="noopener"
                class="text-gray-400 hover:text-white text-sm transition-colors flex items-center gap-1.5 group"
              >
                <svg class="w-3 h-3 text-brand-yellow opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                {dest}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-brand-yellow font-extrabold text-base mb-5">Contacto</h3>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-sm text-gray-400">
            <span class="text-lg shrink-0">📞</span>
            <a href="tel:+573001234567" class="hover:text-white transition-colors">+57 300 123 4567</a>
          </li>
          <li class="flex items-start gap-3 text-sm text-gray-400">
            <span class="text-lg shrink-0">📧</span>
            <a href="mailto:info@alianxatravel.com" class="hover:text-white transition-colors">info@alianxatravel.com</a>
          </li>
          <li class="flex items-start gap-3 text-sm text-gray-400">
            <span class="text-lg shrink-0">📍</span>
            <span>Bogotá, Colombia</span>
          </li>
          <li class="flex items-start gap-3 text-sm text-gray-400">
            <span class="text-lg shrink-0">🕐</span>
            <span>Lun–Sáb: 8am – 7pm</span>
          </li>
        </ul>

        <div class="mt-6">
          <a
            href="https://wa.me/573001234567?text=Hola%20Alianxa%20Travel!%20Quiero%20informaci%C3%B3n%20sobre%20paquetes%20de%20viaje."
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-emerald-600 text-white font-bold text-sm rounded-full hover:bg-emerald-500 transition-all duration-300 hover:scale-105"
          >
            <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.535 5.845L0 24l6.335-1.533C8.049 23.455 9.982 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.807 0-3.496-.487-4.951-1.335l-.355-.21-3.76.91.951-3.659-.232-.375C2.49 15.583 2 13.848 2 12 2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
            Escríbenos
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-gray-500 text-sm">
        © {new Date().getFullYear()} Alianxa Travel. Todos los derechos reservados.
      </p>
      <div class="flex gap-4 text-gray-500 text-xs">
        <a href="#" class="hover:text-white transition-colors">Política de privacidad</a>
        <a href="#" class="hover:text-white transition-colors">Términos y condiciones</a>
      </div>
    </div>
  </div>
</footer>
