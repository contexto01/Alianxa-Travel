---

---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white/95 backdrop-blur-md shadow-sm"
>
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 shrink-0 group"
        aria-label="Alianxa Travel - Inicio"
      >
        <div
          class="w-12 h-12 lg:w-14 lg:h-14 rounded-full overflow-hidden border-2 border-brand-yellow shadow-md transition-transform duration-300 group-hover:scale-105"
        >
          <img
            src="/Logo.webp"
            alt="Alianxa Travel Logo"
            class="w-full h-full object-cover"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
          />
          <div
            class="hidden w-full h-full items-center justify-center bg-gradient-to-br from-brand-blue to-brand-red rounded-full"
          >
            <img src="/Logo.webp" class="w-full h-full rounded-full" alt="" />
          </div>
        </div>
        <div class="hidden sm:block">
          <span class="block text-brand-blue font-black text-lg leading-tight">Alianxa</span>
          <span class="block text-brand-red font-black text-lg leading-tight -mt-1"
            >Travel</span
          >
        </div>
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-8">
        <a href="/#inicio" class="nav-link">Inicio</a>
        <a href="/#nosotros" class="nav-link">Quiénes somos</a>
        <a href="/#destinos" class="nav-link">Destinos</a>
        <a href="/#promociones" class="nav-link">Promociones</a>
        <a href="/#contacto" class="nav-link">Contacto</a>
      </div>

      <!-- CTA + Hamburger -->
      <div class="flex items-center gap-3">
        <a
          href="#cotizar"
          class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 bg-brand-yellow text-brand-dark font-bold rounded-full text-sm transition-all duration-300 hover:bg-yellow-400 hover:scale-105 hover:shadow-lg"
        >
          ✈ Cotizar ahora
        </a>

        <!-- Hamburger -->
        <button
          id="hamburger"
          class="lg:hidden p-2 rounded-lg text-gray-600 hover:text-brand-blue hover:bg-gray-100 transition-colors"
          aria-label="Menú"
          aria-expanded="false"
        >
          <svg
            id="icon-menu"
            class="w-6 h-6 block"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            ><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"
            ></path></svg
          >
          <svg
            id="icon-close"
            class="w-6 h-6 hidden"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            ><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"
            ></path></svg
          >
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="lg:hidden border-t border-gray-100">
      <div class="py-4 space-y-1">
        <a
          href="#inicio"
          class="block px-4 py-2.5 text-gray-700 font-semibold hover:bg-blue-50 hover:text-brand-blue rounded-lg transition-colors"
          >Inicio</a
        >
        <a
          href="#nosotros"
          class="block px-4 py-2.5 text-gray-700 font-semibold hover:bg-blue-50 hover:text-brand-blue rounded-lg transition-colors"
          >Quiénes somos</a
        >
        <a
          href="#destinos"
          class="block px-4 py-2.5 text-gray-700 font-semibold hover:bg-blue-50 hover:text-brand-blue rounded-lg transition-colors"
          >Destinos</a
        >
        <a
          href="#promociones"
          class="block px-4 py-2.5 text-gray-700 font-semibold hover:bg-blue-50 hover:text-brand-blue rounded-lg transition-colors"
          >Promociones</a
        >
        <a
          href="#contacto"
          class="block px-4 py-2.5 text-gray-700 font-semibold hover:bg-blue-50 hover:text-brand-blue rounded-lg transition-colors"
          >Contacto</a
        >
        <div class="px-4 pt-2">
          <a
            href="#cotizar"
            class="block w-full text-center py-3 bg-brand-yellow text-brand-dark font-bold rounded-full"
            >✈ Cotizar ahora</a
          >
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  /* Hamburger menu */
  #mobile-menu {
    transition:
      max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.3s ease;
    max-height: 0;
    opacity: 0;
    overflow: hidden;
  }
  #mobile-menu.open {
    max-height: 400px;
    opacity: 1;
  }

  .nav-link {
    @apply relative font-semibold text-gray-700 hover:text-brand-blue transition-colors duration-200 after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-brand-blue after:transition-all after:duration-300 hover:after:w-full;
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger')!
  const mobileMenu = document.getElementById('mobile-menu')!
  const iconMenu = document.getElementById('icon-menu')!
  const iconClose = document.getElementById('icon-close')!
  const header = document.getElementById('header')!

  hamburger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.toggle('open')
    hamburger.setAttribute('aria-expanded', String(isOpen))
    iconMenu.classList.toggle('hidden', isOpen)
    iconClose.classList.toggle('hidden', !isOpen)
  })

  // Close menu on link click
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.remove('open')
      iconMenu.classList.remove('hidden')
      iconClose.classList.add('hidden')
      hamburger.setAttribute('aria-expanded', 'false')
    })
  })

  // Shadow on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header.classList.add('shadow-md')
    } else {
      header.classList.remove('shadow-md')
    }
  })
</script>
