---
import type { CollectionEntry } from 'astro:content';

interface Props {
  regiones: CollectionEntry<'regiones'>[];
}

const { regiones } = Astro.props;
---

<section class="py-20 lg:py-28 bg-white" aria-label="Destinos por región">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-14 reveal">
      <span class="inline-block px-4 py-1.5 bg-emerald-100 text-emerald-700 text-sm font-bold rounded-full mb-4">
        🌐 Exploración continental
      </span>
      <h2 class="section-title">Viaja por todo el mundo</h2>
      <p class="section-subtitle">Elige tu región favorita y déjate llevar por la aventura</p>
    </div>

    <div class="space-y-8">
      {regiones.slice(0, 3).map((region, i) => (
        <div
          class={`reveal grid lg:grid-cols-2 gap-0 rounded-3xl overflow-hidden shadow-card card-hover ${i % 2 === 1 ? 'lg:[&>*:first-child]:order-2' : ''}`}
        >
          <!-- Image -->
          <div class="relative h-64 lg:h-auto overflow-hidden">
            <img
              src={region.data.imagen}
              alt={`Destinos en ${region.data.nombre}`}
              class="w-full h-full object-cover transition-transform duration-700 hover:scale-105"
              loading="lazy"
            />
            <div class={`absolute inset-0 bg-gradient-to-br ${region.data.color} opacity-50`}></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="text-6xl drop-shadow-2xl">{region.data.icon}</span>
            </div>
          </div>

          <!-- Content -->
          <div class="bg-white p-8 lg:p-10 flex flex-col justify-center">
            <h3 class="text-2xl lg:text-3xl font-black text-brand-dark mb-3">{region.data.nombre}</h3>
            <p class="text-gray-600 leading-relaxed mb-5">{region.data.descripcion}</p>

            <div class="flex flex-wrap gap-2 mb-6">
              {region.data.destinosDestacados.map((dest) => (
                <span class="px-3 py-1 bg-gray-100 text-gray-600 text-sm font-semibold rounded-full hover:bg-brand-yellow hover:text-brand-dark transition-colors cursor-default">
                  📍 {dest}
                </span>
              ))}
            </div>

            <a
              href={`https://wa.me/573001234567?text=${region.data.whatsapp}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 self-start px-6 py-3 bg-brand-blue text-white font-bold rounded-full hover:bg-brand-dark hover:scale-105 transition-all duration-300 shadow-md"
            >
              Conoce más →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Ecotourism Section -->
<section class="relative py-24 overflow-hidden" aria-label="Ecoturismo responsable">
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=1920&q=80&auto=format&fit=crop"
      alt="Naturaleza y ecoturismo responsable"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/75 via-black/50 to-transparent"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-xl">
      <span class="inline-block px-4 py-1.5 bg-emerald-500/20 text-emerald-300 border border-emerald-500/40 text-sm font-bold rounded-full mb-6">
        🌿 Ecoturismo responsable
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-white mb-6 leading-tight">
        Viaja con<br />
        <span class="text-emerald-400">propósito</span>
      </h2>
      <p class="text-white/80 text-lg leading-relaxed mb-8">
        En Alianxa Travel creemos que el turismo puede cambiar el mundo positivamente.
        Promovemos prácticas de viaje que respetan el medioambiente, apoyan las comunidades
        locales y generan experiencias auténticas con impacto real.
      </p>
      <div class="flex flex-wrap gap-4 mb-8">
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <span class="w-8 h-8 bg-emerald-500/30 rounded-full flex items-center justify-center text-base">♻️</span>
          Viajes carbono neutro
        </div>
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <span class="w-8 h-8 bg-emerald-500/30 rounded-full flex items-center justify-center text-base">🤝</span>
          Comunidades locales
        </div>
        <div class="flex items-center gap-2 text-white/80 text-sm">
          <span class="w-8 h-8 bg-emerald-500/30 rounded-full flex items-center justify-center text-base">🌱</span>
          Naturaleza protegida
        </div>
      </div>
      <a
        href="https://wa.me/573001234567?text=Quiero%20conocer%20sus%20paquetes%20de%20ecoturismo"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-emerald-500 text-white font-bold rounded-full hover:bg-emerald-400 hover:scale-105 transition-all duration-300 shadow-lg"
      >
        🌿 Explorar ecoturismo
      </a>
    </div>
  </div>
</section>
